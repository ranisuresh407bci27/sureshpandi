#include <stdio.h>
int main() {
    float a, b, c, largest;
    printf("Enter three numbers: ");
    scanf("%f %f %f", &a, &b, &c);
    largest = a;
    if (b > largest) {
        largest = b;
    }
    if (c > largest) {
        largest = c;
    }
    printf("Largest number = %.2f\n", largest);
    return 0;
}
