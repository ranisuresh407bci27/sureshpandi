#include <stdio.h>
#include <stdlib.h>
int gcd(int a, int b) {
    while (b != 0) {
        int temp = b;
        b = a % b;
        a = temp;
    }
    return abs(a);
}
int main() {
    int a, b;
    printf("Enter two integers: ");
    if (scanf("%d %d", &a, &b) != 2) {
        printf("Invalid input.\n");
        return 1;
    }
    if (a == 0 || b == 0) {
        printf("LCM = 0\n");
        return 0;
    }
    printf("LCM = %d\n", abs(a * b) / gcd(a, b));
    return 0;
}
