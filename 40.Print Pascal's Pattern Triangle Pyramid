#include <stdio.h>
long factorial(int n) {
    long f = 1;
    for(int i = 1; i <= n; i++)
        f *= i;
    return f;
}
int main() {
    int i, j, space, n = 5;
    for(i = 0; i < n; i++) {
        for(space = 0; space < n - i - 1; space++)
            printf("  ");
        for(j = 0; j <= i; j++) {
            long val = factorial(i) / (factorial(j) * factorial(i - j));
            printf("%4ld", val);
        }
        printf("\n");
    }
    return 0;
}
