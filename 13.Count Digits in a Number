#include <stdio.h>
int main() {
    long long num;
    int count = 0;
    printf("Enter an integer: ");
    if (scanf("%lld", &num) != 1) {
        printf("Invalid input.\n");
        return 1;
    }
    if (num == 0) count = 1;
    else {
        while (num != 0) {
            num /= 10;
            count++;
        }
    }
    printf("Number of digits: %d\n", count);
    return 0;
}
