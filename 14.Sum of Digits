#include <stdio.h>
int main() {
    int num, sum = 0; 
    printf("Enter an integer: ");
    if (scanf("%d", &num) != 1) {
        printf("Invalid input.\n");
        return 1;
    }
    while (num != 0) {
        sum += num % 10;
        num /= 10;
    }
    printf("Sum of digits = %d\n", sum);
    return 0;
}
