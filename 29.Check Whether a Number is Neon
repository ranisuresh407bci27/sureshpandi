#include <stdio.h>
int main() {
    int n, square, sum = 0, rem;
    printf("Enter an integer: ");
    scanf("%d", &n);
    square = n * n;
    while (square != 0) {
        rem = square % 10;    
        sum += rem;              
        square /= 10;           
    }
    if (sum == n) {
        printf("%d is a neon number.\n", n);
    } else {
        printf("%d is not a neon number.\n", n);
    }
    return 0;
}
